<?xml version="1.0"?>
<Items>
	<sections>
	<section name="Header.">
    <def name="">
      <namespace name="">
  			Std\fw
  		</namespace>
    </def>
   <def>
  <function_call name="header">
  	<arg name="">
  		<string type="double_quoted" name="">Content-type:text/xml</string>
  	</arg>
    </function_call>
  </def>
  </section>
  <section name="Require onces.">
