  <function_call name="define">
  	<arg name="">
  		<string type="single_quoted">AJAX_HANDLER_1</string>
  	</arg>
  	<arg name="">
  		<string type="double_quoted">ajaxHandler1</string>
  	</arg>
  </function_call>
