   <ref >
    ajaxOps_set_json_enabled_flags_def
	 </ref> 
  </section>
  <section name="Generate ajax handler instance.">
  	<def name="">
  		<var name="">
  			ajaxHandler
  		</var>
  		<constructor_call name="Std_ajax_handler">
  			<const name="">AJAX_HANDLER_1</const>
  		</constructor_call>
  	</def> 
	 </section>
	 <section name="Call ajax handler putData.">
	  <def>
    <method_call instanceName="" name="setOpsContainer">
     <var name="">ajaxHandler</var>
     <arg name="">
       <var name="">ajaxOps</var>
     </arg>
   </method_call>
   </def>
   <def>	
    <method_call instanceName="" name="putData">
     <var name="">ajaxHandler</var>
   </method_call>
  </def>
