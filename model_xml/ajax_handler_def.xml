  		<var name=""> 		
  			ajaxOps	
  		</var>
  		<constructor_call name="AjaxOps_container">
  			<const name="">AJAX_OP_CONTAINER_1</const>
  		</constructor_call>
  	</def>
   <ref >
    ajaxOps_add_instances_to_container_def
	 </ref> 
